# Jeeves — environment template. Copy to .env.local and fill in real values.
# Never commit real secrets; .env* is gitignored (except this example file).

# Neon Postgres connection string (plan.md §4) — used by Drizzle.
DATABASE_URL=postgres://user:password@example-host.neon.tech/jeeves?sslmode=require

# OpenAI runtime LLM (plan.md §1). All LLM calls are mocked in tests.
OPENAI_API_KEY=sk-placeholder-not-a-real-key
OPENAI_MODEL=gpt-5.1

# Passcode gating the live/mutable demo workspace (plan.md §3).
DEMO_PASSCODE=changeme-demo-passcode
